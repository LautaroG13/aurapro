# Postgres
# Puerto host 55432 (no 5432): ver docker-compose.yml, remapeado porque
# 5432 suele estar ocupado por instalaciones nativas de Postgres.
POSTGRES_USER=aurapro
POSTGRES_PASSWORD=aurapro
POSTGRES_DB=aurapro
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
DATABASE_URL=postgresql://aurapro:aurapro@localhost:55432/aurapro

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# Backend (FastAPI)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_ENV=development
SECRET_KEY=change-me

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
